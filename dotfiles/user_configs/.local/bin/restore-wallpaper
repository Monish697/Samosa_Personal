#!/bin/bash

WALLPAPER_DIR="$HOME/Pictures/wallpapers"
STATE_FILE="$HOME/.cache/hyprpaper_index"

mkdir -p "$(dirname "$STATE_FILE")"

mapfile -t wallpapers < <(find "$WALLPAPER_DIR" -maxdepth 1 -type f \( \
    -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" -o -iname "*.webp" \
\) | sort)

COUNT=${#wallpapers[@]}
[ "$COUNT" -eq 0 ] && exit 1

INDEX=0
[ -f "$STATE_FILE" ] && INDEX=$(cat "$STATE_FILE")-1
(( INDEX >= COUNT )) && INDEX=0


# ... (Top half of your script remains the same)

CURRENT="${wallpapers[$INDEX]}"

echo "ok (index $INDEX -> $CURRENT)"

# Wait dynamically until the hyprpaper process is actually running
while ! pgrep -x hyprpaper > /dev/null; do
    sleep 0.5
done

# Give the IPC socket a brief moment to finish binding
sleep 1 

# Preload the image into memory first
hyprctl hyprpaper preload "$CURRENT"

for monitor in $(hyprctl monitors | grep 'Monitor' | awk '{ print $2 }'); do
  # Apply the preloaded wallpaper
  hyprctl hyprpaper wallpaper "$monitor,$CURRENT"
done
